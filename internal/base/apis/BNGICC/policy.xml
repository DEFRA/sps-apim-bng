<!-- Policy with updated App Reg names in APIOps update 15 may 26 12:20 PM -->
<policies>
    <!-- Throttle, authorize, validate, cache, or transform the requests -->
    <inbound>
        <base />
        <validate-jwt header-name="Authorization" failed-validation-httpcode="401" failed-validation-error-message="Unauthorized. Access token is missing or invalid.">
            <openid-config url="https://login.microsoftonline.com/{{COMMON_DEFRA_TENANTID}}/v2.0/.well-known/openid-configuration" />
            <audiences>
                <audience>api://{{BNG_BACKEND_SCOPEID}}/</audience>
            </audiences>
            <issuers>
                <issuer>https://sts.windows.net/{{COMMON_DEFRA_TENANTID}}/</issuer>
            </issuers>
            <required-claims>
                <claim name="appid" match="any">
                    <value>{{BNG_FRONTEND_CLIENTID}}</value>
                </claim>
            </required-claims>
        </validate-jwt>
        <set-query-parameter name="code" exists-action="override">
            <value>{{BNG_BACKEND_APIKEY}}</value>
        </set-query-parameter>
        <set-header name="Authorization" exists-action="delete" />
    </inbound>
    <!-- Control if and how the requests are forwarded to services  -->
    <backend>
        <base />
    </backend>
    <!-- Customize the responses -->
    <outbound>
        <base />
    </outbound>
    <!-- Handle exceptions and customize error responses  -->
    <on-error>
        <base />
    </on-error>
</policies>
