<policies>
	<inbound>
		<!-- Policy with updated App Reg names in APIOps. This is updated on 06/May/2025 part1-->
		<base />
		<rate-limit calls="120" renewal-period="60" />
		<set-query-parameter name="code" exists-action="override">
        <value>{{BNG_BACKEND_APIKEY}}</value>
        </set-query-parameter>
		<validate-jwt header-name="Authorization" failed-validation-httpcode="401" failed-validation-error-message="Unauthorized. Access token is missing or invalid.">
			<openid-config url="https://login.microsoftonline.com/#{{ defraTenantId }}/v2.0/.well-known/openid-configuration" />
			<audiences>
				<audience>api://{{BNGICC_BACKEND_SCOPEID}}</audience>
			</audiences>
			<issuers>
				<issuer>https://sts.windows.net/#{{ defraTenantId }}/</issuer>
			</issuers>
			<required-claims>
				<claim name="appid" match="any">
					<value>{{BNGICC_FRONTEND_CLIENTID}}</value>
				</claim>
			</required-claims>
		</validate-jwt>
		<set-backend-service backend-id="BNGICC-backend" />
	</inbound>
	<backend>
		<base />
	</backend>
	<outbound>
		<base />
	</outbound>
	<on-error>
		<base />
	</on-error>
</policies>
